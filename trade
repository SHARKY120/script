--// THEME (bisa kamu ubah)
local THEME_COLOR = Color3.fromRGB(0,255,200)

--// SAVE SYSTEM (opsional, tergantung executor)
local saveFile = "jekak_ui_pos.txt"

local function savePos(pos)
    if writefile then
        writefile(saveFile, game:GetService("HttpService"):JSONEncode({x=pos.X.Scale,y=pos.Y.Scale}))
    end
end

local function loadPos()
    if readfile and isfile and isfile(saveFile) then
        local data = game:GetService("HttpService"):JSONDecode(readfile(saveFile))
        return UDim2.new(data.x,0,data.y,0)
    end
    return UDim2.new(0.5,-60,0,20)
end

